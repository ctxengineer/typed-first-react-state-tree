{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["es2023", "DOM"],
		"moduleDetection": "force",
		"module": "preserve",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"types": [],
		"strict": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"allowImportingTsExtensions": true,
		"jsx": "react-jsx",
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@/lib/typed-first": ["./src/entry.ts"],
			"@/lib/typed-first/use": ["./src/entry-use.ts"],
			"@/*": ["./src/*"],
			"tests/*": ["./tests/*"]
		}
	},
	"include": ["src", "tests"]
}
