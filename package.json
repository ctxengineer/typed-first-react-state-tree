{
	"name": "typed-first-react-state-tree",
	"version": "0.2.0",
	"private": false,
	"description": "Proof-of-concept React state tree for type-driven UI state modeling.",
	"scripts": {
		"build": "tsdown",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"react",
		"state",
		"hooks",
		"observable",
		"typescript"
	],
	"author": "ctxengineer",
	"license": "MIT",
	"dependencies": {
		"@legendapp/state": "^3.0.0-beta.31"
	},
	"peerDependencies": {
		"react": ">=18.0.0 <20",
		"react-dom": ">=18.0.0 <20"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.8.3",
		"@happy-dom/global-registrator": "^18.0.1",
		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/bun": "^1.2.20",
		"@types/react": "^19.1.0",
		"happy-dom": "^15.11.7",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tsdown": "^0.12.8",
		"type-fest": "^4.41.0",
		"typescript": "^5.6.2",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^2.1.8"
	},
	"type": "module",
	"files": [
		"dist/**/*"
	],
	"module": "./dist/index.js",
	"main": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./use": {
			"import": "./dist/use.js",
			"types": "./dist/use.d.ts",
			"default": "./dist/use.js"
		}
	},
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ctxengineer/typed-first-react-state-tree.git"
	},
	"bugs": {
		"url": "https://github.com/ctxengineer/typed-first-react-state-tree/issues"
	},
	"homepage": "https://github.com/ctxengineer/typed-first-react-state-tree#readme",
	"engines": {
		"node": ">=18",
		"npm": ">=9"
	}
}
